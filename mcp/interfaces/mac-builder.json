{
  "name": "visionos-mac-builder",
  "version": 1,
  "status": "mock-implemented",
  "boundary": "Runs native Xcode and visionOS SDK operations on an audited Mac host. The browser simulator and Vision Pro client never receive signing assets or deployment authority.",
  "mockServer": {
    "command": "pnpm dev:mac-builder:mock",
    "defaultUrl": "http://127.0.0.1:3101",
    "endpoints": [
      "GET /health",
      "POST /jobs",
      "GET /jobs",
      "GET /jobs/:id"
    ]
  },
  "awsEc2MacDeployment": {
    "workflowDocument": "docs/workflows/aws-ec2-mac-builder.md",
    "hostModel": "EC2 Mac Dedicated Host",
    "minimumHostAllocationHours": 24,
    "preferredConnectivity": ["SSM Session Manager", "private SSH", "private builder API"],
    "artifactStore": "S3 with SSE-KMS",
    "logStore": "CloudWatch Logs",
    "secretStore": "AWS Secrets Manager or SSM Parameter Store plus macOS keychain",
    "defaultBuilderUrlEnv": "VISIONOS_MAC_BUILDER_URL"
  },
  "capabilities": [
    {
      "id": "visionos.preflight",
      "input": ["repoRef", "xcodeVersion"],
      "output": ["hostStatus", "sdkStatus", "signingStatus"]
    },
    {
      "id": "visionos.generateProject",
      "input": ["repoRef", "generator"],
      "output": ["changedFiles", "logs"]
    },
    {
      "id": "visionos.build",
      "input": ["repoRef", "scheme", "configuration", "destination"],
      "output": ["buildStatus", "logs", "xcresultRef"]
    },
    {
      "id": "visionos.testSimulator",
      "input": ["repoRef", "scheme", "destination"],
      "output": ["testStatus", "logs", "screenshots", "xcresultRef"]
    },
    {
      "id": "visionos.archive",
      "input": ["repoRef", "scheme", "exportMethod"],
      "output": ["archiveStatus", "artifactRef", "xcresultRef"]
    }
  ],
  "secrets": {
    "allowedInsideAdapter": ["signing identities", "provisioning profiles", "App Store Connect credentials"],
    "forbiddenToClient": ["private keys", "tokens", "certificates", "profiles", "deployment credentials"]
  }
}
