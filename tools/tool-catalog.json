{
  "version": 1,
  "notes": [
    "Native visionOS compilation still requires macOS, Xcode, and the visionOS SDK.",
    "This catalog separates currently runnable Linux tools from optional and future Mac-builder tools."
  ],
  "tools": [
    {
      "id": "node",
      "name": "Node.js",
      "mode": "local-required",
      "command": "node",
      "workflow": ["web-simulator", "gateway", "doctor", "compliance"]
    },
    {
      "id": "pnpm",
      "name": "pnpm",
      "mode": "local-required",
      "command": "pnpm",
      "workflow": ["monorepo", "typecheck", "build"]
    },
    {
      "id": "git",
      "name": "Git",
      "mode": "local-required",
      "command": "git",
      "workflow": ["source-control", "compliance"]
    },
    {
      "id": "docker",
      "name": "Docker",
      "mode": "local-required",
      "command": "docker",
      "workflow": ["ttyd", "code-server", "future-remote-browser"]
    },
    {
      "id": "docker-compose",
      "name": "Docker Compose",
      "mode": "local-required",
      "command": "docker compose",
      "workflow": ["dev-services"]
    },
    {
      "id": "ttyd",
      "name": "ttyd",
      "mode": "docker-runnable",
      "githubUrl": "https://github.com/tsl0922/ttyd",
      "dockerImage": "tsl0922/ttyd:alpine",
      "endpoint": "http://127.0.0.1:7681",
      "workflow": ["terminal-window"]
    },
    {
      "id": "code-server",
      "name": "code-server",
      "mode": "docker-runnable",
      "githubUrl": "https://github.com/coder/code-server",
      "dockerImage": "codercom/code-server:latest",
      "endpoint": "http://127.0.0.1:8080",
      "workflow": ["code-window"]
    },
    {
      "id": "playwright",
      "name": "Playwright",
      "mode": "node-runnable",
      "githubUrl": "https://github.com/microsoft/playwright",
      "nodePackage": "@playwright/test",
      "workflow": ["web-simulator-e2e", "visual-regression"]
    },
    {
      "id": "gltf-validator",
      "name": "glTF Validator",
      "mode": "node-runnable",
      "githubUrl": "https://github.com/KhronosGroup/glTF-Validator",
      "nodePackage": "gltf-validator",
      "workflow": ["asset-validation"]
    },
    {
      "id": "mac-builder-mock",
      "name": "Mock Mac Builder",
      "mode": "node-runnable",
      "command": "node",
      "workflow": ["mock-native-build-control-plane", "mac-builder-e2e"]
    },
    {
      "id": "aws-cli",
      "name": "AWS CLI",
      "mode": "optional-cloud-toolchain",
      "command": "aws",
      "workflow": ["future-aws-ec2-mac-provisioning", "future-s3-artifacts", "future-cloudwatch-logs"]
    },
    {
      "id": "aws-mac-cost-guard",
      "name": "AWS Mac Builder Cost Guard",
      "mode": "node-runnable",
      "command": "node",
      "workflow": ["aws-budget-check", "aws-mac-host-block", "aws-baseline-deploy-guard"]
    },
    {
      "id": "aws-ec2-mac",
      "name": "Amazon EC2 Mac",
      "mode": "cloud-mac-builder",
      "workflow": ["future-native-build", "future-official-simulator", "future-archive"]
    },
    {
      "id": "aws-ssm",
      "name": "AWS Systems Manager Session Manager",
      "mode": "optional-cloud-toolchain",
      "command": "aws",
      "workflow": ["future-private-mac-builder-access"]
    },
    {
      "id": "aws-s3",
      "name": "Amazon S3",
      "mode": "cloud-artifact-store",
      "command": "aws",
      "workflow": ["future-build-artifacts", "future-xcresult-storage"]
    },
    {
      "id": "aws-cloudwatch",
      "name": "Amazon CloudWatch Logs",
      "mode": "cloud-log-store",
      "command": "aws",
      "workflow": ["future-mac-builder-logs"]
    },
    {
      "id": "sourcekit-lsp",
      "name": "SourceKit-LSP",
      "mode": "optional-swift-toolchain",
      "githubUrl": "https://github.com/swiftlang/sourcekit-lsp",
      "command": "sourcekit-lsp",
      "workflow": ["future-swift-source-intelligence"]
    },
    {
      "id": "swift-format",
      "name": "swift-format",
      "mode": "optional-swift-toolchain",
      "githubUrl": "https://github.com/swiftlang/swift-format",
      "command": "swift-format",
      "workflow": ["future-swift-formatting"]
    },
    {
      "id": "xcodegen",
      "name": "XcodeGen",
      "mode": "optional-mac-builder",
      "githubUrl": "https://github.com/yonaskolb/XcodeGen",
      "command": "xcodegen",
      "workflow": ["future-xcode-project-generation"]
    },
    {
      "id": "tuist",
      "name": "Tuist",
      "mode": "optional-mac-builder",
      "githubUrl": "https://github.com/tuist/tuist",
      "command": "tuist",
      "workflow": ["future-xcode-project-generation"]
    },
    {
      "id": "xcode",
      "name": "Xcode",
      "mode": "mac-only",
      "command": "xcodebuild",
      "workflow": ["future-native-build", "future-official-simulator", "future-device-debug"]
    },
    {
      "id": "xcodebuild",
      "name": "xcodebuild",
      "mode": "mac-only",
      "command": "xcodebuild",
      "workflow": ["future-mac-builder-only"]
    },
    {
      "id": "xcrun",
      "name": "xcrun",
      "mode": "mac-only",
      "command": "xcrun",
      "workflow": ["future-mac-builder-only"]
    },
    {
      "id": "xcrun-simctl",
      "name": "xcrun simctl",
      "mode": "mac-only",
      "command": "xcrun",
      "workflow": ["future-official-simulator"]
    },
    {
      "id": "xcresulttool",
      "name": "xcresulttool",
      "mode": "mac-only",
      "command": "xcrun",
      "workflow": ["future-build-result-export"]
    },
    {
      "id": "reality-composer-pro",
      "name": "Reality Composer Pro",
      "mode": "mac-only",
      "workflow": ["future-spatial-asset-authoring"]
    },
    {
      "id": "apple-transporter",
      "name": "Apple Transporter",
      "mode": "mac-only",
      "workflow": ["future-app-store-upload"]
    },
    {
      "id": "app-store-connect-api",
      "name": "App Store Connect API",
      "mode": "apple-service",
      "workflow": ["future-release-automation", "future-build-polling", "future-testflight-management"]
    },
    {
      "id": "appuploader-cli",
      "name": "AppUploader CLI",
      "mode": "optional-third-party-release-tool",
      "workflow": ["future-optional-ipa-upload", "future-signing-inspection", "future-profile-management"]
    },
    {
      "id": "fastlane",
      "name": "Fastlane",
      "mode": "optional-release-tool",
      "githubUrl": "https://github.com/fastlane/fastlane",
      "command": "fastlane",
      "workflow": ["future-release-lane", "future-metadata-automation"]
    },
    {
      "id": "xcode-cloud",
      "name": "Xcode Cloud",
      "mode": "apple-service",
      "workflow": ["future-managed-apple-builds"]
    },
    {
      "id": "apple-developer-account",
      "name": "Apple Developer Program account",
      "mode": "apple-account-required",
      "workflow": ["future-signing", "future-device-registration", "future-testflight"]
    },
    {
      "id": "apple-vision-pro",
      "name": "Apple Vision Pro",
      "mode": "device-required",
      "workflow": ["future-device-test"]
    }
  ]
}
