{
  "version": 1,
  "name": "visionos-development",
  "hardBoundary": "Native visionOS build, signing, official simulator, device install, TestFlight, and App Store submission require macOS, Xcode, the visionOS SDK, and Apple-controlled credentials.",
  "nativeProject": {
    "sourceRoot": "native/visionos",
    "generator": "xcodegen",
    "generatorSpecPath": "native/visionos/project.yml",
    "projectPath": "native/visionos/VisionWebWorkspace.xcodeproj",
    "scheme": "VisionWebWorkspace"
  },
  "defaultTarget": {
    "configuration": "Debug",
    "destination": "platform=visionOS Simulator,name=Apple Vision Pro",
    "sdk": "xrsimulator"
  },
  "phases": [
    {
      "id": "preflight",
      "title": "Tool and boundary preflight",
      "capabilities": ["linux-runnable"],
      "command": "pnpm visionos:preflight",
      "produces": ["local tool status", "workflow compliance status"]
    },
    {
      "id": "web-simulator",
      "title": "Spatial web workspace simulator",
      "capabilities": ["linux-runnable"],
      "command": "pnpm dev:web",
      "produces": ["movable web windows", "layout behavior", "session URL behavior"]
    },
    {
      "id": "gateway",
      "title": "Controlled session gateway",
      "capabilities": ["linux-runnable"],
      "command": "pnpm dev:gateway",
      "produces": ["terminal session descriptors", "code session descriptors", "audit lifecycle events"]
    },
    {
      "id": "developer-surfaces",
      "title": "Browser developer surfaces",
      "capabilities": ["linux-runnable"],
      "command": "pnpm dev:services",
      "produces": ["ttyd terminal", "code-server IDE"]
    },
    {
      "id": "local-gate",
      "title": "Local workflow gate",
      "capabilities": ["linux-runnable"],
      "command": "pnpm workflow:check",
      "produces": ["tool doctor", "compliance result", "typecheck", "build"]
    },
    {
      "id": "mock-mac-builder",
      "title": "Mock Mac builder adapter",
      "capabilities": ["linux-runnable", "mcp-candidate"],
      "command": "pnpm dev:mac-builder:mock",
      "produces": ["mock build jobs", "mock logs", "mock artifacts", "mock xcresult references"]
    },
    {
      "id": "web-e2e",
      "title": "Browser workspace e2e",
      "capabilities": ["linux-runnable"],
      "command": "pnpm test:e2e",
      "produces": ["Playwright smoke result"]
    },
    {
      "id": "mac-builder-e2e",
      "title": "Mac builder control-plane e2e",
      "capabilities": ["linux-runnable", "mcp-candidate"],
      "command": "pnpm test:mac-builder",
      "produces": ["job lifecycle result", "adapter client result", "artifact reference result"]
    },
    {
      "id": "aws-ec2-mac-builder-plan",
      "title": "AWS EC2 Mac builder deployment plan",
      "capabilities": ["mac-builder-required", "mcp-candidate"],
      "command": null,
      "produces": ["Dedicated Host plan", "Mac bootstrap plan", "AWS artifact/log plan", "teardown plan"]
    },
    {
      "id": "aws-mac-worker-guard",
      "title": "AWS Mac worker quota and cost guard",
      "capabilities": ["mac-builder-required", "mcp-candidate"],
      "command": "pnpm aws:mac:worker:quota-status && pnpm aws:mac:worker:cost-status",
      "produces": ["Dedicated Host quota status", "current spend status", "24h minimum estimate", "live Mac resource inventory"]
    },
    {
      "id": "xcode-artifact-plan",
      "title": "Xcode artifact handoff plan",
      "capabilities": ["mac-builder-required", "apple-account-required", "mcp-candidate"],
      "command": "pnpm aws:mac:xcode:plan",
      "produces": ["Xcode.xip upload instructions", "S3 artifact target", "Mac-side verification command"]
    },
    {
      "id": "native-gateway-protocol",
      "title": "Native visionOS Gateway protocol",
      "capabilities": ["linux-runnable"],
      "command": "pnpm test:e2e",
      "produces": ["workspace layout API result", "session creation API result", "native client contract smoke result"]
    },
    {
      "id": "swift-source-intelligence",
      "title": "Swift source intelligence",
      "capabilities": ["optional-swift-toolchain"],
      "command": null,
      "produces": ["SourceKit-LSP diagnostics", "swift-format results"]
    },
    {
      "id": "native-project-generation",
      "title": "Native Xcode project generation",
      "capabilities": ["mac-builder-required", "mcp-candidate"],
      "command": "pnpm visionos:native:plan",
      "produces": ["Xcode project state", "generated native source"]
    },
    {
      "id": "native-build",
      "title": "Native visionOS build",
      "capabilities": ["mac-builder-required", "mcp-candidate"],
      "command": "pnpm visionos:mac-build:check",
      "produces": ["xcodebuild logs", "build products", "xcresult bundle"]
    },
    {
      "id": "official-simulator-debug",
      "title": "Official simulator debug",
      "capabilities": ["mac-builder-required", "mcp-candidate"],
      "command": null,
      "produces": ["simulator logs", "screenshots", "debug diagnostics"]
    },
    {
      "id": "device-test",
      "title": "Apple Vision Pro device test",
      "capabilities": ["mac-builder-required", "device-required", "mcp-candidate"],
      "command": null,
      "produces": ["device install result", "device logs", "manual or automated test record"]
    },
    {
      "id": "release",
      "title": "TestFlight and App Store release",
      "capabilities": ["mac-builder-required", "apple-account-required", "mcp-candidate"],
      "command": null,
      "produces": ["signed archive", "exported IPA", "upload result"]
    },
    {
      "id": "app-store-release-plan",
      "title": "App Store and TestFlight release plan",
      "capabilities": ["mac-builder-required", "apple-account-required", "mcp-candidate"],
      "command": null,
      "produces": ["signing preflight", "IPA validation", "upload backend policy", "TestFlight checklist", "review checklist"]
    }
  ]
}
